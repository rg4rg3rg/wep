# Kullanıcı adı varsayılan olarak admin'dir.
ADMIN_USERNAME=admin

# `npm run hash-password -- "guclu-sifreniz"` çıktısını buraya yapıştırın.
ADMIN_PASSWORD_HASH=$2b$12$BURAYA_BCRYPT_OZETI_GELECEK

# En az 32 karakterlik rastgele bir değer kullanın.
# Örnek üretim: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=BURAYA_UZUN_RASTGELE_BIR_DEGER_GELECEK

PORT=3000
NODE_ENV=development
MAX_FILE_SIZE_MB=2048
TZ=Europe/Istanbul

# İsteğe bağlı harici mutlak yollar:
# UPLOAD_DIR=/var/data/uploads
# SESSION_DIR=/var/data/sessions
