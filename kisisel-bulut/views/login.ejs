<main class="login-shell">
  <section class="login-card" aria-labelledby="login-title">
    <div class="logo"><i class="fa-solid fa-cloud" aria-hidden="true"></i></div>
    <p class="eyebrow">Kişisel Bulut</p>
    <h1 id="login-title">Tekrar hoş geldin.</h1>
    <p class="muted">Özel dosya alanına erişmek için giriş yap.</p>

    <% if (error) { %>
      <div class="toast toast-error toast-static" role="alert">
        <i class="fa-solid fa-circle-exclamation" aria-hidden="true"></i>
        <span><%= error %></span>
      </div>
    <% } %>

    <form action="/login" method="post" class="login-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label for="username">Kullanıcı adı</label>
      <div class="input-wrap">
        <i class="fa-regular fa-user" aria-hidden="true"></i>
        <input id="username" name="username" type="text" value="admin"
          autocomplete="username" autocapitalize="none" required autofocus>
      </div>
      <label for="password">Şifre</label>
      <div class="input-wrap">
        <i class="fa-solid fa-lock" aria-hidden="true"></i>
        <input id="password" name="password" type="password"
          autocomplete="current-password" required>
      </div>
      <button type="submit" class="button button-primary button-wide">
        <span>Giriş yap</span><i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
      </button>
    </form>
  </section>
</main>
